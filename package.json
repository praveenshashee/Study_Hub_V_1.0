{
  "name": "study-hub-v1-0",
  "private": true,
  "scripts": {
    "postinstall": "npm install --prefix backend && npm install --prefix frontend",
    "dev": "concurrently \"npm run dev:api\" \"npm run dev:web\"",
    "dev:api": "npm run dev --prefix backend",
    "dev:web": "npm run dev --prefix frontend",
    "build": "npm run build --prefix frontend",
    "start": "npm run build && npm start --prefix backend"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
